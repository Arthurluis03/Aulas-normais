let nota 
do {
    nota = +prompt(`Digite a nota dos alunos:  `)
    if (nota > 0 && nota <= 10 ){
        alert(`Notas validas, registrado com sucesso `)
    } else{
        alert("Notas invalidas")
    }
}while(nota < 0 || nota > 10)
