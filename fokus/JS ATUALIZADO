export default function ativaButtonTemp() {

const banner = document.querySelector('.app__image')
const titulos = document.querySelector('.app__title')
const html = document.documentElement /* Trazendo elemento html fora do body */
const botoes = document.querySelectorAll('.app__card-button[data-contexto]')

botoes.forEach(itemBotoes => {
    itemBotoes.addEventListener('click', () => {
        let contexto = itemBotoes.dataset.contexto
        alterarConteudos(contexto, itemBotoes) // Chamando a função das ações
    })
})


// Função que vai executar as ações do evento de click nos botões
function alterarConteudos(contexto, botaoClicado) {

    // Removendo classe ativa dos elementos
    botoes.forEach(itemBotao => itemBotao.classList.remove('active'))

    // Adicionando a classe ativa nos elementos
    botaoClicado.classList.add('active')

    // Atualizando o data-contexto
    html.dataset.contexto = contexto

    // Atualizando as imagens
    banner.src = `imagens/${contexto}.png`
    //
    // tentativa de mudança de tempo
    
    switch (contexto) {
        case 'foco':

            alarme.style.background = `linear-gradient(180deg, #8B1FF8 0%, #041832 48.44%, #01080E 100%)`
            alarme.style.boxShadow = '0 0 40px rgba(139, 31, 248, 0.6)';
            titulos.innerHTML = `
            Otimize sua produtividade,<br>
            <strong class="app_title-strong"> mergulhe no que importa. </strong>
            `
           tempoDecorrido = 100
            mostrarTimer()
            break;

        case 'descanso-curto':
            alarme.style.background = 'linear-gradient(180deg, #0F745C 0%, #041832 48.44%, #01080E 100%)'
            alarme.style.boxShadow = '0 0 40px rgba(15, 114, 92, 0.6)';
            titulos.innerHTML = `
            Otimize sua produtividade,<br>
            <strong class="app_title-strong">
                Faça uma pausa curta!
            </strong>
            `
            tempoDecorrido = 300
            mostrarTimer()
            break;

        case 'descanso-longo':
            alarme.style.background = 'linear-gradient(180deg, #1875E9 0%, #041832 48.44%, #01080E 100%)'
            alarme.style.boxShadow = '0 0 40px rgba(24, 117, 233, 0.6)';
            titulos.innerHTML = `
            Otimize sua produtividade,<br>
            <strong class="app_title-strong">
                Faça uma pausa longa!
            </strong>
            `
            tempoDecorrido = 500
            mostrarTimer()
            break;
        
        default:
            titulos.innerText = 'Contexto não encontrado'
    }
}

// Início codificação Temporizador
const exibirTimerApp = document.getElementById('timer')
let btn = document.querySelector('.app__card-primary-button')
let p = document.querySelector('.app__card-second-button')
let reset = document.querySelector('.app__card-reset-button')

// ERRO DUAS VEZES, É MUITA BURRICE

btn.addEventListener('click', iniciarTimer)
p.addEventListener('click', pararTimer)
reset.addEventListener('click', resetTimer)

////////////// MEXER 
function resetTimer() {
    switch (contexto) {
        case 'foco':
            tempoDecorrido = 100
            break;
        case 'descanso-curto':
            tempoDecorrido = 300
            break;
        case 'descanso-longo':
            tempoDecorrido = 500
            break;
    }
   
    mostrarTimer()
    pararTimer()
}

let tempoDecorrido = 5

// Variável de referencia para guardar o timer

function mostrarTimer(){
    // Instanciando objeto Date para manipular o temporizador
    const tempo = new Date(tempoDecorrido * 1000)
    const tempoFormatado = tempo.toLocaleTimeString('pt-br', {minute: '2-digit', second: '2-digit'})
    exibirTimerApp.innerHTML = `${tempoFormatado}`
    
}
mostrarTimer()
let mPlay = new Audio ('sons/play.wav')
let mPause = new Audio ('sons/pause.mp3') 
let som = new Audio ('sons/alarme.mp3') // coloquei a musica que queria, mas pode ser qualquer uma
let alarme = document.querySelector('.app_card-second-button-alarm')
let mMusica = new Audio('sons/musica.mp3')
let msc = false
let msc_app = document.querySelector('.app__card-list-item')
msc_app.addEventListener('click', () => {
    msc = !msc 
    if (msc == true) {
        som.currentTime = 135;
        mMusica.play()
    } else {
        mMusica.pause()
    }
})

function decrescerTimer() {
    if (tempoDecorrido <= 0) {
        pararTimer()
        alarme.classList.add('active')
        som.currentTime = 135;
        som.play()
        return 
    }
    tempoDecorrido -= 1
    mostrarTimer(); 
} 
        alarme.addEventListener('click', () => {
        alarme.classList.remove('active')
        som.pause()
        })
let idTimer
let rodando = false
function iniciarTimer() {
    if (rodando) {return}
    mPlay.play() 
    reset.style.display = 'flex'
    p.parentElement.style.display = 'flex'
    btn.parentElement.style.display = 'none'
    
    idTimer = setInterval(decrescerTimer, 1000)
    rodando = true 
    if (msc == true) {
        mMusica.play()
    } else {
        mMusica.pause()
    }
}


function pararTimer() {
    clearInterval(idTimer)
    rodando = false
    mMusica.pause()
    mPause.play()
    p.parentElement.style.display = 'none'
    btn.parentElement.style.display = 'flex' 
    reset.style.display = 'none'

} 
}




